                  "name": "Prose",
                  "fill": "$ink-muted",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Nearline 7200 SAS drives share identical platters with their SATA equivalents; only the interface board differs. Thinner consumer demand means used pulls undercut the SATA twin by roughly C$80–120 a drive — and a single ~C$85 LSI 9300-16i HBA pays for itself across the first three. SAS power has no 3.3V disable pin either, so that hack disappears.",
                  "lineHeight": 1.5,
                  "fontFamily": "$font-sans",
                  "fontSize": "$size-13",
                  "fontWeight": "$w-regular"
                },
